# ═══════════════════════════════════════════════════════════
#  CRM Omnichannel — Variáveis de Ambiente
#  Copie para .env e preencha com seus valores reais
# ═══════════════════════════════════════════════════════════

# ==========================================
# 🛠️ INFRAESTRUTURA LOCAL
# ==========================================
DB_URL=jdbc:postgresql://localhost:5432/crm_db
DB_USER=postgres
DB_PASS=postgres_dev_2026
REDIS_HOST=localhost
REDIS_PORT=6379
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ==========================================
# 🌐 APLICAÇÃO
# ==========================================
APP_PORT=8080
APP_ENV=development
JWT_SECRET=sua_chave_jwt_super_secreta_aqui
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ==========================================
# 🔌 IXC Soft (ERP do Provedor)
# ==========================================
IXC_API_URL=https://seu-ixc.com.br/webservice/v1
IXC_API_TOKEN=seu_token_base64_aqui
IXC_SYNC_CRON=0 0 2 * * ?
# Cron: todo dia às 02:00 AM

# ==========================================
# 💬 OPA Suite (Mensageria WhatsApp)
# ==========================================
OPA_API_URL=https://seu-opa.ixcsoft.com.br/api/v1
OPA_API_TOKEN=seu_token_opa_aqui
OPA_WEBHOOK_SECRET=segredo_para_validar_webhook_hmac
OPA_RATE_LIMIT=60
# Máximo de mensagens por minuto

# ==========================================
# 📞 NeWave (Telefonia SIP / PABX)
# ==========================================
NEWAVE_API_URL=http://ip_do_newave/api
NEWAVE_WSS_URL=wss://ip_do_newave:8089/ws
NEWAVE_ADMIN_USER=admin
NEWAVE_ADMIN_PASS=senha_admin_newave
NEWAVE_SIP_DOMAIN=ip_do_newave
NEWAVE_STUN_URL=stun:ip_do_newave:3478
NEWAVE_TURN_URL=turn:ip_do_newave:3478
NEWAVE_TURN_USER=turnuser
NEWAVE_TURN_PASS=turnpassword

# ==========================================
# 🧠 INTELIGÊNCIA ARTIFICIAL LOCAL (EVELYN)
# ==========================================
OLLAMA_API_URL=http://localhost:11434
LLM_MODEL_NAME=llama3
# Modelos suportados: llama3, mistral, gemma, phi3
# Escolha baseado no hardware disponível:
#   - llama3 (8B) → requer ~8GB RAM, GPU recomendada
#   - mistral (7B) → requer ~6GB RAM
#   - phi3 (3.8B) → leve, funciona em CPU
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=1536
AI_CONFIDENCE_THRESHOLD=0.75
# Confiança mínima para ações autônomas (0.00 a 1.00)

# ==========================================
# 📊 MONITORAMENTO (Fase 7)
# ==========================================
# PROMETHEUS_ENABLED=true
# GRAFANA_ADMIN_PASS=admin
# ELASTIC_URL=http://localhost:9200

# ==========================================
# 🔒 SEGURANÇA
# ==========================================
# KEYCLOAK_URL=http://localhost:8180
# KEYCLOAK_REALM=crm-realm
# KEYCLOAK_CLIENT_ID=crm-app
# KEYCLOAK_CLIENT_SECRET=sua_chave_keycloak
